---
import { render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import BitCard from './BitCard.astro';
import Lightbox from './Lightbox.astro';
import '../styles/bits-page.css';
import { MAX_PRIMARY_BITS_FILTER_YEARS, getBitsDerivedText, type BitsEntry, type BitsYearOption } from '../lib/bits';
import { containsMarkdownMath } from '../lib/markdown-math';
import {
  MARKDOWN_MATH_STYLESHEET_DATA_ATTR,
  MARKDOWN_MATH_STYLESHEET_HREF,
  MARKDOWN_MATH_STYLESHEET_ID
} from '../lib/markdown-math-styles';
import { createWithBase } from '../utils/format';
import { getThemeSettings } from '../lib/theme-settings';
import { joinPageSubtitleText } from '../utils/format';

const {
  currentPage,
  items,
  nextPath = null,
  prevPath = null,
  resultCount,
  totalPages,
  yearOptions = []
} = Astro.props as {
  currentPage: number;
  items: BitsEntry[];
  nextPath?: string | null;
  prevPath?: string | null;
  resultCount: number;
  totalPages: number;
  yearOptions?: BitsYearOption[];
};

const base = import.meta.env.BASE_URL ?? '/';
const withBase = createWithBase(base);
const {
  settings: {
    page
  }
} = getThemeSettings();

const pageTitleText = page.bits.title || '絮语';
const pageTitleParts = [pageTitleText, currentPage > 1 ? `第 ${currentPage} 页` : null].filter(Boolean);
const pageTitle = pageTitleParts.join(' · ');
const subtitleText = joinPageSubtitleText(
  page.bits.subtitle,
  totalPages > 1 ? `第 ${currentPage} / ${totalPages} 页` : null
);
const pageDescription = joinPageSubtitleText(
  `${pageTitleText}列表`,
  page.bits.subtitle,
  `共 ${resultCount} 条絮语`,
  totalPages > 1 ? `第 ${currentPage} / ${totalPages} 页` : null
) ?? `${pageTitleText}列表`;

const primaryYearOptions = yearOptions.slice(0, MAX_PRIMARY_BITS_FILTER_YEARS);
const overflowYearOptions = yearOptions.slice(MAX_PRIMARY_BITS_FILTER_YEARS);
const priorityMediaBitId = items.find((bit) => (bit.data.images?.length ?? 0) > 0)?.id ?? null;

const cards = await Promise.all(
  items.map(async (bit) => {
    const derivedText = getBitsDerivedText(bit);
    if (derivedText.shouldRenderFull) {
      const { Content } = await render(bit);
      return { bit, excerpt: '', Content, hasMath: containsMarkdownMath(bit.body ?? '') };
    }
    return { bit, excerpt: derivedText.excerpt, Content: null, hasMath: false };
  })
);
const hasRenderedMath = cards.some((card) => card.hasMath);
const katexStylesheetAttrs = { [MARKDOWN_MATH_STYLESHEET_DATA_ATTR]: 'true' };
---

<BaseLayout title={pageTitle} description={pageDescription}>
  {hasRenderedMath ? (
    <link
      slot="head"
      id={MARKDOWN_MATH_STYLESHEET_ID}
      rel="stylesheet"
      href={MARKDOWN_MATH_STYLESHEET_HREF}
      {...katexStylesheetAttrs}
    />
  ) : null}

  <div class="page-header page-header--bits">
    <div class="page-heading">
      <h1 class="page-title">{pageTitleText}</h1>
      {subtitleText ? <span class="page-subtitle">{subtitleText}</span> : null}
    </div>
  </div>

  <div class="bits-toolbar">
    <div class="bits-controls">
      {yearOptions.length > 0 ? (
        <div
          class="bits-year-filter"
          data-bits-year-filter
          data-bits-client-control
          role="group"
          aria-label="按年份筛选絮语"
        >
          <span class="bits-year-filter__cursor" data-bits-year-cursor aria-hidden="true"></span>
          <button
            class="bits-year-filter__item bits-year-filter__item--all is-active"
            type="button"
            data-bits-year-item
            data-bits-year=""
            aria-label="显示全部絮语"
            aria-pressed="true"
          >
            全部
          </button>
          {primaryYearOptions.map((option) => (
            <button
              class="bits-year-filter__item"
              type="button"
              data-bits-year-item
              data-bits-year={option.value}
              aria-label={`筛选 ${option.value} 年絮语，共 ${option.count} 条`}
              aria-pressed="false"
            >
              {option.value}
            </button>
          ))}
          {overflowYearOptions.length > 0 ? (
            <div class="bits-year-more" data-bits-year-more data-open="false">
              <button
                class="bits-year-filter__item bits-year-filter__item--more"
                type="button"
                data-bits-year-more-trigger
                aria-label="打开更多年份筛选"
                aria-expanded="false"
                aria-controls="bits-year-more-menu"
              >
                <span data-bits-year-more-label>更多</span>
                <span class="bits-year-filter__caret" aria-hidden="true"></span>
              </button>
              <div
                class="bits-year-menu"
                id="bits-year-more-menu"
                data-bits-year-menu
                hidden
                aria-label="更多年份筛选"
              >
                <div class="bits-year-menu__list">
                  {overflowYearOptions.map((option) => (
                    <button
                      class="bits-year-menu__item"
                      type="button"
                      data-bits-year-menu-item
                      data-bits-year={option.value}
                      aria-label={`筛选 ${option.value} 年絮语，共 ${option.count} 条`}
                      aria-pressed="false"
                    >
                      <span class="bits-year-menu__item-label">{option.value}</span>
                      <span class="bits-year-menu__item-count">{option.count} 条</span>
                    </button>
                  ))}
                </div>
              </div>
            </div>
          ) : null}
        </div>
      ) : null}

      <div class="bits-controls__actions">
        <div class="bits-controls__search-cluster" data-has-year-filter={yearOptions.length > 0 ? 'true' : 'false'}>
          <form class="bits-search" role="search" data-bits-search-form data-bits-client-control>
            <label class="sr-only" for="bits-search">搜索絮语</label>
            <input
              id="bits-search"
              type="search"
              placeholder="搜索：关键词 / 标签"
              autocomplete="off"
              enterkeyhint="search"
              aria-controls="bits-search-results-panel"
            />
            <button class="bits-search-btn" id="bits-search-btn" type="submit" aria-controls="bits-search-results-panel">
              搜索
            </button>
          </form>
          {yearOptions.length > 0 ? (
            <div class="bits-year-select-wrap" data-bits-client-control>
              <label class="sr-only" for="bits-year-select">按年份筛选絮语</label>
              <select
                class="bits-year-select"
                id="bits-year-select"
                data-bits-year-select
                aria-label="按年份筛选絮语"
              >
                <option value="">全部</option>
                {yearOptions.map((option) => (
                  <option value={option.value}>{option.value}</option>
                ))}
              </select>
            </div>
          ) : null}
        </div>
        <!-- bits draft trigger intentionally disabled; keep implementation in source for future restoration. -->
      </div>
    </div>
    <div class="bits-status" id="bits-search-status"></div>
    <p class="sr-only" id="bits-search-live" role="status" aria-live="polite" aria-atomic="true"></p>
    <!-- bits draft load status intentionally disabled with the trigger. -->
  </div>

  <div data-bits-browse>
    <div id="bits-list">
      {cards.map(({ bit, excerpt, Content }) => (
        <BitCard bit={bit} excerpt={excerpt} Content={Content} prioritizeLeadMedia={bit.id === priorityMediaBitId} />
      ))}
    </div>

    {totalPages > 1 ? (
      <nav class="pagination" aria-label={`${pageTitleText}分页`}>
        <div class="pagination__inner">
          {prevPath ? <a class="pagination__link" rel="prev" href={withBase(prevPath)}>上一页</a> : null}
          {nextPath ? (
            <a class="pagination__link pagination__link--next" rel="next" href={withBase(nextPath)}>下一页</a>
          ) : null}
        </div>
      </nav>
    ) : null}
  </div>

  <section
    id="bits-search-results-panel"
    class="bits-search-results"
    data-bits-search-results
    hidden
    aria-label="搜索结果"
  >
    <div class="bits-search-results__header">
      <p class="bits-search-results__summary" data-bits-search-results-summary role="status" aria-live="polite">搜索结果</p>
      <button class="bits-search-results__clear" type="button" data-bits-search-clear>重置筛选</button>
    </div>
    <div class="bits-search-results__list" data-bits-search-results-list></div>
  </section>

  <noscript>
    <style>
      [data-bits-client-control] {
        display: none !important;
      }
    </style>
    <p class="bits-noscript-note">搜索、年份筛选与草稿生成功能需要 JavaScript，当前仅保留列表浏览。</p>
  </noscript>

  <!-- bits draft dialog mount intentionally disabled with the trigger. -->
  <Lightbox
    id="lightbox"
    label="图片预览"
    enableZoom={true}
    enablePan={true}
    enableSwipeDownClose={true}
    mobileNav="hidden"
    mobileCount="hidden"
  />

  <script>
    import '../scripts/bits-search.ts';
    import '../scripts/bits-lightbox.ts';
  </script>
</BaseLayout>
