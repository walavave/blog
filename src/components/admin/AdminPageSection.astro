---
import AdminIcon from './AdminIcon.astro';
import AdminHelpTip from './AdminHelpTip.astro';
import {
  ADMIN_ARTICLE_META_DATE_LABEL_MAX_LENGTH,
  ADMIN_SEARCH_SUBRESULT_LIMIT_DEFAULT,
  ADMIN_SEARCH_SUBRESULT_LIMIT_MAX,
  ADMIN_SEARCH_SUBRESULT_LIMIT_MIN
} from '../../lib/admin-console/theme-shared';

interface Props {
  pageTitleMaxLength: number;
  pageSubtitleMaxLength: number;
  memoTitlePlaceholder?: string;
  memoSubtitlePlaceholder?: string;
}

const {
  pageTitleMaxLength,
  pageSubtitleMaxLength,
  memoTitlePlaceholder = '',
  memoSubtitlePlaceholder = ''
} = Astro.props;
---

<fieldset class="admin-group">
  <legend class="admin-group__legend">
    <AdminIcon name="admin-page" class="admin-group__legend-icon" size={14} />
    <span class="admin-group__legend-copy">
      <span class="admin-group__legend-zh">内页设置</span>
      <span class="admin-group__legend-en">Inner pages</span>
    </span>
  </legend>
  <div class="admin-grid">
    <label class="admin-field">
      <span class="admin-label">
        <span class="admin-label__main">
          <code>/essay/</code> 页面主 <span class="admin-label__pipe" aria-hidden="true">|</span> 副标题
        </span>
      </span>
      <span class="admin-title-pair" role="group" aria-label="/essay/ 页面主标题与副标题">
        <input
          id="page-essay-title"
          class="admin-title-pair__input admin-title-pair__input--title"
          type="text"
          maxlength={pageTitleMaxLength}
          autocomplete="off"
          placeholder="随笔"
          aria-label="/essay/ 页面主标题"
        />
        <span class="admin-title-pair__sep" aria-hidden="true">|</span>
        <input
          id="page-essay-subtitle"
          class="admin-title-pair__input admin-title-pair__input--subtitle"
          type="text"
          maxlength={pageSubtitleMaxLength}
          autocomplete="off"
          placeholder="随笔与杂记"
          aria-label="/essay/ 页面副标题"
        />
      </span>
    </label>
    <label class="admin-field">
      <span class="admin-label">
        <span class="admin-label__main">搜索子结果最大数量</span>
        <span class="admin-label__hint">（每篇随笔最多显示的命中位置）</span>
      </span>
      <input
        class="admin-field__control"
        id="page-essay-search-subresult-limit"
        type="number"
        min={ADMIN_SEARCH_SUBRESULT_LIMIT_MIN}
        max={ADMIN_SEARCH_SUBRESULT_LIMIT_MAX}
        step="1"
        inputmode="numeric"
        value={ADMIN_SEARCH_SUBRESULT_LIMIT_DEFAULT}
      />
    </label>
    <label class="admin-field">
      <span class="admin-label">
        <span class="admin-label__main">
          <code>/bits/</code> 页面主 <span class="admin-label__pipe" aria-hidden="true">|</span> 副标题
        </span>
      </span>
      <span class="admin-title-pair" role="group" aria-label="/bits/ 页面主标题与副标题">
        <input
          id="page-bits-title"
          class="admin-title-pair__input admin-title-pair__input--title"
          type="text"
          maxlength={pageTitleMaxLength}
          autocomplete="off"
          placeholder="絮语"
          aria-label="/bits/ 页面主标题"
        />
        <span class="admin-title-pair__sep" aria-hidden="true">|</span>
        <input
          id="page-bits-subtitle"
          class="admin-title-pair__input admin-title-pair__input--subtitle"
          type="text"
          maxlength={pageSubtitleMaxLength}
          autocomplete="off"
          placeholder="生活不只是长篇"
          aria-label="/bits/ 页面副标题"
        />
      </span>
    </label>
    <div class="admin-field admin-field--full admin-field--memo">
      <span class="admin-label">
        <span class="admin-label__main">
          <code>/memo/</code> 页面主 <span class="admin-label__pipe" aria-hidden="true">|</span> 副标题
        </span>
        <AdminHelpTip
          id="page-memo-title-tip"
          label="/memo/ 页面标题说明"
          text="填写后覆盖对应字段，留空则沿用 src/content/memo/index.md。"
        />
      </span>
      <span class="admin-title-pair" role="group" aria-label="/memo/ 页面主标题与副标题">
        <input
          id="page-memo-title"
          class="admin-title-pair__input admin-title-pair__input--title"
          type="text"
          maxlength={pageTitleMaxLength}
          autocomplete="off"
          placeholder={memoTitlePlaceholder || undefined}
          aria-label="/memo/ 页面主标题"
          aria-describedby="page-memo-title-tip"
        />
        <span class="admin-title-pair__sep" aria-hidden="true">|</span>
        <input
          id="page-memo-subtitle"
          class="admin-title-pair__input admin-title-pair__input--subtitle"
          type="text"
          maxlength={pageSubtitleMaxLength}
          autocomplete="off"
          placeholder={memoSubtitlePlaceholder || undefined}
          aria-label="/memo/ 页面副标题"
          aria-describedby="page-memo-title-tip"
        />
      </span>
    </div>
    <label class="admin-field">
      <span class="admin-label">
        <span class="admin-label__main">
          <code>/archive/</code> 页面主 <span class="admin-label__pipe" aria-hidden="true">|</span> 副标题
        </span>
      </span>
      <span class="admin-title-pair" role="group" aria-label="/archive/ 页面主标题与副标题">
        <input
          id="page-archive-title"
          class="admin-title-pair__input admin-title-pair__input--title"
          type="text"
          maxlength={pageTitleMaxLength}
          autocomplete="off"
          placeholder="归档"
          aria-label="/archive/ 页面主标题"
        />
        <span class="admin-title-pair__sep" aria-hidden="true">|</span>
        <input
          id="page-archive-subtitle"
          class="admin-title-pair__input admin-title-pair__input--subtitle"
          type="text"
          maxlength={pageSubtitleMaxLength}
          autocomplete="off"
          placeholder="按年份分组的归档目录"
          aria-label="/archive/ 页面副标题"
        />
      </span>
    </label>
    <label class="admin-field">
      <span class="admin-label">
        <span class="admin-label__main">
          <code>/about/</code> 页面主 <span class="admin-label__pipe" aria-hidden="true">|</span> 副标题
        </span>
      </span>
      <span class="admin-title-pair" role="group" aria-label="/about/ 页面主标题与副标题">
        <input
          id="page-about-title"
          class="admin-title-pair__input admin-title-pair__input--title"
          type="text"
          maxlength={pageTitleMaxLength}
          autocomplete="off"
          placeholder="关于"
          aria-label="/about/ 页面主标题"
        />
        <span class="admin-title-pair__sep" aria-hidden="true">|</span>
        <input
          id="page-about-subtitle"
          class="admin-title-pair__input admin-title-pair__input--subtitle"
          type="text"
          maxlength={pageSubtitleMaxLength}
          autocomplete="off"
          aria-label="/about/ 页面副标题"
        />
      </span>
    </label>
  </div>

  <div class="admin-subgroup">
    <p class="admin-subtitle">
      <span class="admin-subtitle__main">文章元信息</span>
      <span class="admin-subtitle__hint">（字数/时长仅详情页，移动端隐藏）</span>
    </p>
    <div class="admin-toggle-row-group admin-toggle-row-group--article-meta">
      <div class="admin-toggle-row admin-toggle-row--with-inline-field">
        <label class="admin-toggle-row admin-toggle-row--compact" for="ui-article-meta-show-date">
          <input id="ui-article-meta-show-date" type="checkbox" />
          <span>显示发布日期</span>
        </label>
        <span class="admin-toggle-row__sep" aria-hidden="true">|</span>
        <label class="admin-inline-field" for="ui-article-meta-date-label">
          <span class="admin-inline-field__label">前缀：</span>
          <input
            id="ui-article-meta-date-label"
            class="admin-inline-field__input"
            type="text"
            maxlength={ADMIN_ARTICLE_META_DATE_LABEL_MAX_LENGTH}
            autocomplete="off"
            placeholder="发布于："
          />
        </label>
      </div>
      <label class="admin-toggle-row">
        <input id="ui-article-meta-show-tags" type="checkbox" />
        <span>显示标签</span>
      </label>
      <label class="admin-toggle-row">
        <input id="ui-article-meta-show-word-count" type="checkbox" />
        <span>显示字数</span>
      </label>
      <label class="admin-toggle-row">
        <input id="ui-article-meta-show-reading-time" type="checkbox" />
        <span>显示阅读时长</span>
      </label>
    </div>
    <p class="admin-help admin-help--article-meta-preview">
      预览：<code id="article-meta-preview-value" class="admin-help__preview-value">{'发布于：2026-03-18 · #Astro\u00A0\u00A0#写作 · 共 2,416 字 · 约 6 分钟'}</code>
    </p>
  </div>

  <div class="admin-subgroup">
    <p class="admin-subtitle">
      <span class="admin-subtitle__main">/bits/页默认作者</span>
    </p>
    <div class="admin-author-image">
      <div class="admin-author-image__fields">
        <label class="admin-field">
          <span class="admin-label">
            <span class="admin-label__main">默认作者名</span>
          </span>
          <input class="admin-field__control" id="page-bits-author-name" type="text" autocomplete="off" />
        </label>
        <div class="admin-field">
          <span class="admin-label">
            <label class="admin-label__main" for="page-bits-author-avatar">默认头像</label>
            <span class="admin-label__hint">（相对路径）</span>
          </span>
          <div class="admin-images-field-input">
            <input class="admin-field__control" id="page-bits-author-avatar" type="text" autocomplete="off" />
            <button
              class="admin-btn admin-btn--ghost"
              type="button"
              data-admin-images-open="page.bits.defaultAuthor.avatar"
              aria-label="选择 Bits 默认头像"
            >
              选择
            </button>
          </div>
        </div>
      </div>
      <div class="admin-author-image__preview" aria-label="默认头像预览">
        <p class="admin-images-field-preview-label">预览头像</p>
        <div
          class="admin-images-field-preview admin-images-field-preview--avatar"
          data-admin-images-preview="page.bits.defaultAuthor.avatar"
          hidden
        >
          <img alt="" loading="lazy" decoding="async" data-admin-images-preview-img="page.bits.defaultAuthor.avatar" />
        </div>
      </div>
    </div>
  </div>
</fieldset>
