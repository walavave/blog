---
import AdminIcon from './AdminIcon.astro';
import {
  ADMIN_TYPOGRAPHY_DEFAULT,
  getAdminTypographyFontOptions
} from '../../lib/admin-console/theme-shared';

const typographyFields = [
  { role: 'readable', label: '正文字体', hint: '（文章正文与标题）' },
  { role: 'copy', label: '文案字体', hint: '（导语、关于页等楷体场景）' },
  { role: 'mono', label: '等宽字体', hint: '（代码块与行内代码）' },
  { role: 'brand', label: '品牌字体', hint: '（侧栏站点名与引言）' }
] as const;
---

<fieldset class="admin-group">
  <legend class="admin-group__legend">
    <AdminIcon name="admin-code" class="admin-group__legend-icon" size={14} />
    <span class="admin-group__legend-copy">
      <span class="admin-group__legend-zh">代码显示</span>
      <span class="admin-group__legend-en">Code</span>
    </span>
  </legend>
  <div class="admin-stack">
    <label class="admin-toggle-row">
      <input id="ui-code-line-numbers" type="checkbox" />
      <span>在代码块中显示行号</span>
    </label>
  </div>
</fieldset>

<fieldset class="admin-group">
  <legend class="admin-group__legend">
    <AdminIcon name="palette" class="admin-group__legend-icon" size={14} />
    <span class="admin-group__legend-copy">
      <span class="admin-group__legend-zh">排版字体</span>
      <span class="admin-group__legend-en">Typography</span>
    </span>
  </legend>
  <div class="admin-stack">
    {
      typographyFields.map((field) => {
        const options = getAdminTypographyFontOptions(field.role);
        const defaultId = ADMIN_TYPOGRAPHY_DEFAULT[field.role];
        return (
          <div class="admin-field admin-field--typography">
            <span class="admin-label">
              <span class="admin-label__main">{field.label}</span>
              <span class="admin-label__hint">{field.hint}</span>
            </span>
            <div
              class="admin-font-grid"
              id={`ui-typography-${field.role}`}
              role="radiogroup"
              aria-label={field.label}
            >
              {options.map((option) => (
                <label class="admin-font-card" for={`ui-typography-${field.role}-${option.id}`}>
                  <input
                    id={`ui-typography-${field.role}-${option.id}`}
                    name={`ui-typography-${field.role}`}
                    type="radio"
                    value={option.id}
                    checked={option.id === defaultId}
                  />
                  <span class="admin-font-card__body">
                    <span class="admin-font-card__preview" aria-hidden="true" style={`font-family: ${option.previewStack};`}>
                      永 Aa
                    </span>
                    <span class="admin-font-card__name">{option.cardLabel}</span>
                    <span class="admin-font-card__badge">{option.badge}</span>
                  </span>
                </label>
              ))}
            </div>
          </div>
        );
      })
    }
  </div>
</fieldset>
