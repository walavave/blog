---
import { render } from 'astro:content';
import { getEssaySlug, getVisibleEssayRouteEntries, type EssayEntry } from '../../lib/content';
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import { createWithBase } from '../../utils/format';
import { getThemeSettings, getVisibleArticleMetaTags } from '../../lib/theme-settings';
import { rewriteRenderedContentImageUrls } from '../../lib/content-local-images.mjs';

type ArticleNeighborLink = {
  href: string;
  title: string;
};

export const prerender = true;

export async function getStaticPaths() {
  const base = import.meta.env.BASE_URL ?? '/';
  const withBase = createWithBase(base);
  const routeEntries = await getVisibleEssayRouteEntries();
  return routeEntries.map(({ slug, entry, prev, next }) => {
    return {
      params: { slug },
      props: {
        entry,
        prev: prev
          ? { href: withBase(`/archive/${getEssaySlug(prev)}/`), title: prev.data.title }
          : null,
        next: next
          ? { href: withBase(`/archive/${getEssaySlug(next)}/`), title: next.data.title }
          : null
      }
    };
  });
}

const { entry, prev, next } = Astro.props as {
  entry: EssayEntry;
  prev: ArticleNeighborLink | null;
  next: ArticleNeighborLink | null;
};
const entrySourcePath = typeof (entry as { filePath?: unknown })?.filePath === 'string'
  ? (entry as { filePath?: string }).filePath ?? null
  : null;
const entryWithContentImages = entry.rendered && entrySourcePath
  ? {
      ...entry,
      rendered: {
        ...entry.rendered,
        html: rewriteRenderedContentImageUrls({
          html: entry.rendered.html,
          sourceFilePath: entrySourcePath,
          base: import.meta.env.BASE_URL ?? '/',
          requireExists: true,
          devFs: import.meta.env.DEV
        })
      }
    }
  : entry;
const { Content } = await render(entryWithContentImages);
const articleMetaSettings = getThemeSettings().settings.ui.articleMeta;
const visibleTags = getVisibleArticleMetaTags(entry.data.tags, 'detail');
---

<ArticleLayout
  entry={entryWithContentImages}
  prev={prev}
  next={next}
  articleMetaSettings={articleMetaSettings}
  visibleTags={visibleTags}
>
  <Content />
</ArticleLayout>
